{{!
    @template mod_pdfprotect/mobile

    Example context (json):
    {
        "cmid": 123,
        "iframe-url": "https://example.com/video.mp4"
    }
}}
{{=<% %>=}}

<div class="mod-pdfprotect-mobile">
    <core-course-module-description
            description="<% description %>"
            component="mod_pdfprotect"
            componentId="<% cmid %>">
    </core-course-module-description>

    <ion-card>
        <ion-card-header>
            <ion-card-title><% name %></ion-card-title>
        </ion-card-header>

        <ion-card-content>
            <p>{{ "plugin.mod_pdfprotect.mobileopeninfo" | translate }}</p>

            <ion-button
                    expand="block"
                    href="<% viewurl %>"
                    core-link
                    [capture]="false"
                    [autoLogin]="'yes'"
                    [inApp]="true">
                {{ "plugin.mod_pdfprotect.mobileopen" | translate }}
            </ion-button>
        </ion-card-content>
    </ion-card>
</div>